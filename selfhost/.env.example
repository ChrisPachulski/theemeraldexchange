# The Emerald Exchange — self-host configuration.
# install.sh copies this to .env and generates the four secrets for you.
# NEVER commit .env.

# REQUIRED: absolute path to your media folder on this machine.
# Subfolders like Movies/ and TV/ are scanned automatically.
MEDIA_PATH=

# ── Generated by install.sh (leave blank; kept if already set) ──
SESSION_SECRET=
STREAM_TOKEN_SECRET=
DEVICE_TOKEN_SECRET=
INTERNAL_PRINCIPAL_SECRET=
RECOMMENDER_EVENT_SECRET=
USE_LOCAL_RECOMMENDER=1

# ── Optional: remote access (private, via your Tailscale tailnet) ──
# COMPOSE_PROFILES=remote
# TS_AUTHKEY=            # from https://login.tailscale.com/admin/settings/keys
# TS_HOSTNAME=emerald

# ── Optional: richer metadata/discovery (free key: themoviedb.org) ──
# TMDB_READ_ACCESS_TOKEN=
# TMDB_API_KEY=

# ── Optional: requests & downloads (existing Sonarr/Radarr/SAB) ──
# SONARR_URL=
# SONARR_API_KEY=
# RADARR_URL=
# RADARR_API_KEY=
# SAB_URL=
# SAB_API_KEY=
# DEFAULT_ROOT_FOLDER_PATH=

# ── Optional: live TV (your Xtream/IPTV provider) ──
# XTREAM_HOST=
# XTREAM_USERNAME=
# XTREAM_PASSWORD=

# ── Optional: Plex login as an extra sign-in provider ──
# PLEX_CLIENT_ID=
# PLEX_SERVER_ID=
# Emergency production boot opt-in when Plex is configured without a server id.
# This does not bypass an existing members/provider gate. Prefer setup-token claim.
# ALLOW_UNSCOPED_PLEX_LOGIN=0

# ── Optional: login providers and administrator bootstrap ──
# Legacy Plex usernames and stable namespaced identities that should be admin.
# Prefer the first-owner setup-token flow; these remain useful for recovery.
# ADMINS=
# ADMIN_SUBS=
# APPLE_CLIENT_ID=        # setting an id enables Apple
# ENABLE_APPLE_SIGN_IN=   # optional fail-fast assertion
# GOOGLE_CLIENT_ID=       # comma-separate web + native OAuth client ids
# ENABLE_GOOGLE_SIGN_IN=  # optional fail-fast assertion

# Passkeys default to localhost. When using Tailscale HTTPS or another stable
# hostname, bind credentials to that host and list the exact browser origin.
# WEBAUTHN_RP_ID=emerald.example.ts.net
# WEBAUTHN_RP_NAME=The Emerald Exchange
# WEBAUTHN_ORIGINS=https://emerald.example.ts.net
# First-owner claims accept private/loopback sources only. Set to 1 only when
# claiming through a trusted remote tunnel; the setup token remains required.
# SETUP_ALLOW_REMOTE=0

# ── Optional: Intel iGPU transcoding (also uncomment devices: in compose) ──
# TRANSCODER_HW_ENCODER=vaapi
