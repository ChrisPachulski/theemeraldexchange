# Local development only — copy to .env.local and fill in real values.
# Real values are in /mnt/user/appdata/{sonarr,radarr,sabnzbd}/* on the NAS.
# These are read by vite.config.ts at dev-server startup and injected
# into proxied requests; they are NOT exposed to the browser.

SONARR_API_KEY=
RADARR_API_KEY=
SAB_API_KEY=
