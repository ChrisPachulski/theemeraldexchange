# Local development only — copy to .env.local and fill in real values.
# The backend loads .env.local at boot (server/env.ts), NOT .env, so put
# every value below into .env.local (both are gitignored). Real production
# values for the *arr bridges live in /mnt/user/appdata/{sonarr,radarr,sabnzbd}/*
# on the NAS. Vars marked "REQUIRED in production" throw at boot if unset
# under NODE_ENV=production; in dev most are optional so localhost boots
# with whatever halves you've configured.
#
# Secrets hygiene: this repo may go public. Every value here is a blank
# placeholder or a safe default (port, path, cron). NEVER commit a real
# secret, key, token, hostname, or IP — generate secrets locally with the
# recipes shown and keep them in .env.local only.

# ── Optional services (compose profiles — plan 006 Phase 4) ──────────────
# The core stack (backend, media-core, transcoder, recommender) always
# runs. Everything else is opt-in via COMPOSE_PROFILES (comma-separated):
#   remote            — PRIVATE remote access: Tailscale Serve (tailnet-only
#                       https://<TS_HOSTNAME>.<tailnet>.ts.net; needs
#                       TS_AUTHKEY from the Tailscale admin console).
#   remote-cloudflare — PUBLIC remote access: Cloudflare Tunnel (needs
#                       TUNNEL_TOKEN + a domain; the owner deployment path).
#   telemetry         — self-hosted Glitchtip error tracking (pair with
#                       TELEMETRY_ENABLED=1 + the GLITCHTIP_* keys).
COMPOSE_PROFILES=
TS_AUTHKEY=
TS_HOSTNAME=emerald

# ── *arr / SAB bridges ───────────────────────────────────────────────────
# API keys for the download-automation stack. Read by the backend only;
# injected into upstream requests server-side, never exposed to the
# browser. OPTIONAL since plan 006 Phase 0: leave any
# of them empty and that integration is simply not configured — its routes
# return a typed 503 <service>_not_configured and the SPA hides the
# request/download features. Set all three for the full request pipeline.
SONARR_API_KEY=
RADARR_API_KEY=
SAB_API_KEY=

# Backing service URLs. Defaults match the existing NAS setup; override
# here if your install is elsewhere or if the urlBase paths (Sonarr /tv,
# Radarr /movies) differ.
# SONARR_URL=http://your-nas.local:8989/tv
# RADARR_URL=http://your-nas.local:7878/movies
# SAB_URL=http://your-nas.local:8080

# Local Plex Media Server, used to enumerate every account that has ever
# accessed the server (/accounts) — the canonical "who actually watches
# here" list. Defaults to http://<NAS_HOST>:32400; override if elsewhere.
# PLEX_SERVER_URL=http://your-nas.local:32400

# ── Auth / session ───────────────────────────────────────────────────────

# Stable UUID identifying this app to plex.tv. OPTIONAL since plan 006
# Phase 0: leave empty and Plex login is simply not configured (the Plex
# auth routes 503 plex_not_configured and clients hide the Plex button).
# When using Plex, generate once with
# `node -e "console.log(crypto.randomUUID())"` and keep it constant —
# rotating logs every user out. The value is matched as an exact string by
# plex.tv, so no trailing whitespace/newline.
PLEX_CLIENT_ID=

# 32+ random bytes used to derive the A256GCM key (via SHA-256) that
# ENCRYPTS session cookies as JWE. The cookie payload includes the user's
# Plex auth token, so encryption — not just signing — keeps it opaque if
# the cookie is ever captured or logged. REQUIRED to boot; in production it
# additionally must be >=32 chars and not a known placeholder. Generate with
# `node -e "console.log(crypto.randomBytes(48).toString('base64url'))"` (or
# `openssl rand -base64 48`). Rotating invalidates every existing session.
SESSION_SECRET=

# Dedicated signing+verifying secret for IPTV/media stream tokens, kept
# separate from SESSION_SECRET so a stream-token compromise can't expose
# session cookies and rotation stays scoped. REQUIRED to boot. Generate with
# `openssl rand -base64 48`. Must be DISTINCT from every other *_SECRET
# (a boot-time pairwise check throws on a copy-paste duplicate).
STREAM_TOKEN_SECRET=

# IKM for the AES-256-GCM key that encrypts device-token JWEs (Apple Bearer
# auth). REQUIRED in production; optional in dev so localhost without Apple
# pairing still boots (mint paths re-check and throw). Generate with
# `openssl rand -base64 48`. Must be distinct from the other *_SECRETs.
DEVICE_TOKEN_SECRET=

# IKM for the AES-256-GCM key on the JWE the server attaches to every
# internal service call (recommender, media-core, transcoder). 60s TTL.
# REQUIRED in production once any internal service is wired; tolerated absent
# in dev so localhost work without the sidecar boots (mint paths re-check and
# throw). Without it, playback grants fail closed with 502
# `principal_mint_failed` when media-core IS enabled. Generate with
# `openssl rand -base64 48`. Must be distinct from the other *_SECRETs.
INTERNAL_PRINCIPAL_SECRET=

# Comma-separated Plex usernames that get the `admin` role. Everyone else
# who is a member of the home server gets `user`. Empty == no admins.
ADMINS=

# Comma-separated namespaced subs (apple:<subject> | plex:<id>) that are
# admins AND implicitly allowed without an invite — the owner bootstrap, so
# your own first login on a fresh install needs no invite. Each entry is
# parseSub-validated at boot (a malformed entry throws). Use this for
# apple: subs, which have no stable Plex username for the ADMINS path.
ADMIN_SUBS=

# machineIdentifier of the home Plex server. When unset (default), any
# authenticated Plex user is allowed in — and /api/auth/plex/check returns
# the user's servers in `discoveredServers` so you can grab the id and lock
# things down. REQUIRED in production unless ALLOW_UNSCOPED_PLEX_LOGIN=1.
PLEX_SERVER_ID=

# First-deploy escape hatch: set to 1 to accept ANY authenticated Plex user
# when PLEX_SERVER_ID is unset. Intended only for the brief bootstrap window
# to discover your server id; remove it immediately after. Off (unset/!=1).
ALLOW_UNSCOPED_PLEX_LOGIN=

# Sign in with Apple. The Apple Services ID / bundle id used as the `aud`
# claim when verifying a SIWA identity token against Apple's public JWKS
# (no client secret needed). Optional in dev; REQUIRED in production only
# when ENABLE_APPLE_SIGN_IN=1. Leave both unset to run Plex-only.
APPLE_CLIENT_ID=
ENABLE_APPLE_SIGN_IN=

# Passkeys (WebAuthn) — the password-free identity spine.
#   WEBAUTHN_RP_ID    — Relying Party id: the registrable domain the passkey
#                       binds to (e.g. theemeraldexchange.com). Must be the
#                       origin's host or a parent domain. Default "localhost".
#   WEBAUTHN_RP_NAME  — human-facing name shown in the OS passkey prompt.
#                       Default "The Emerald Exchange".
#   WEBAUTHN_ORIGINS  — comma-separated allowed origins (scheme+host[+port])
#                       an assertion may come from. Defaults to ALLOWED_ORIGINS
#                       (then localhost:5173/3001 in dev); override only when
#                       the login page lives on a different origin.
WEBAUTHN_RP_ID=
WEBAUTHN_RP_NAME=
WEBAUTHN_ORIGINS=

# ── Server / network ─────────────────────────────────────────────────────

# Backend listen port. Default 3001.
PORT=3001

# REQUIRED in production: comma-separated SPA origins allowed for CORS AND
# CSRF (e.g. https://theemeraldexchange.com). Prod cookies are SameSite=None
# for the Netlify <-> NAS split, so an empty list would fail open — the
# backend throws if unset in prod. Leave blank in dev (Vite proxy makes
# everything same-origin).
ALLOWED_ORIGINS=

# Set to 1 to trust Cloudflare/proxy client-IP headers for per-client auth
# rate limits. Keep off (unset) unless the backend is reachable ONLY through
# that proxy, or a client could spoof the header to evade rate limits.
TRUST_CLIENT_IP_HEADERS=

# Log verbosity: debug | info | warn | error. Default info. Read straight
# from process.env by server/services/logger.ts.
LOG_LEVEL=

# ── *arr add policy ──────────────────────────────────────────────────────

# Preferred quality-profile name for non-admin adds. Case-insensitive.
# Default "choose me" — mirrors the frontend's "Choose Me" preference so
# non-admin direct POSTs land on the curated profile, not profiles[0].
DEFAULT_PROFILE_NAME=

# Exact upstream root-folder paths for non-admin adds. REQUIRED in production
# (both, or DEFAULT_ROOT_FOLDER_PATH as a shared fallback for both). These
# are the paths AS Sonarr/Radarr see them, not local paths.
DEFAULT_ROOT_FOLDER_PATH=
DEFAULT_SONARR_ROOT_FOLDER_PATH=
DEFAULT_RADARR_ROOT_FOLDER_PATH=

# Minimum free space (GB) required on a Sonarr/Radarr root folder before
# /add succeeds. Below this, both admins and users get a 507
# "insufficient_disk_space" — everyone is gated by design. Default 100.
MIN_FREE_GB=100

# Hard cap on movie release size (GB) at add-time; we grab the highest
# quality at or under this. Prevents accidental 50GB 4K HDR rips. Default 10.
MAX_MOVIE_SIZE_GB=10

# Hard cap on TV release size expressed PER EPISODE (GB). A release passes
# when size/episodeCount <= this. Default 5 (blocks 4K HDR, allows 1080p).
MAX_TV_GB_PER_EPISODE=5

# Per-session rate-limit budgets for the *arr / SAB proxy mutations (each
# add/upgrade/search triggers a real upstream indexer search + disk I/O).
# capacity = burst, refill = sustained tokens per intervalMs. Defaults: 12 /
# 12 / 60000ms — generous for a household, cuts off a hammering loop.
ARR_MUTATE_RATE_CAPACITY=12
ARR_MUTATE_RATE_REFILL=12
ARR_MUTATE_RATE_INTERVAL_MS=60000

# ── TMDB enrichment (optional) ───────────────────────────────────────────
# When set, the detail modal fetches cast for movies/TV. Without them the
# cast section is hidden; everything else still works. Prefer the read token
# so server-side calls use the Authorization header instead of URL secrets.
TMDB_READ_ACCESS_TOKEN=
TMDB_API_KEY=

# ── Local recommender sidecar ────────────────────────────────────────────
# Set USE_LOCAL_RECOMMENDER=1 to make /api/suggestions ask the Python +
# sqlite-vec recommender for ranked picks instead of Claude. When on,
# RECOMMENDER_EVENT_SECRET is REQUIRED (the backend throws without it).
USE_LOCAL_RECOMMENDER=
# Recommender base URL. Default is environment-conditional:
# http://recommender:8000 in prod (compose hostname), http://localhost:8000
# in dev. Set explicitly when hand-running the sidecar elsewhere.
RECOMMENDER_URL=
# Shared secret signing recommender event ingest. Generate with
# `openssl rand -base64 48`. In prod it must also be >=32 chars and not a
# placeholder. Required whenever USE_LOCAL_RECOMMENDER=1.
RECOMMENDER_EVENT_SECRET=
# Recommender's SQLite DB (exchange.db). The backend opens it read-only to
# report its migration level via /api/version; it never migrates it.
# Default ./data/exchange.db.
RECOMMENDER_DB_PATH=./data/exchange.db

# ── Media-core + transcoder (local playback) ─────────────────────────────
# Set USE_MEDIA_CORE=1 to mount /api/media and the library tab. With it off,
# the media library tab never mounts. When on in production,
# INTERNAL_PRINCIPAL_SECRET (above) must be set or playback grants 502.
USE_MEDIA_CORE=
# media-core base URL. Default http://media-core:8002 in prod (compose
# hostname), http://127.0.0.1:8002 in dev. Only consumed when USE_MEDIA_CORE=1.
MEDIA_CORE_URL=
# Transcoder base URL for files that can't direct-play; its HLS manifests are
# proxied back through /api/transcode. Default http://transcoder:8003 in prod,
# http://127.0.0.1:8003 in dev. Only consumed when USE_MEDIA_CORE=1.
MEDIA_TRANSCODER_URL=
# media-core's library DB (media.db). Opened READ-ONLY by the backend for
# availability tagging; media-core owns all writes. Default ./data/media.db.
MEDIA_DB_PATH=./data/media.db
# TTL (secs) for local-media playback stream tokens. Unlike IPTV's per-request
# tokens, a movie token must outlast a whole sitting (presented on every
# byte-range / HLS segment). Default 21600 (6h); scopes one user to one title.
MEDIA_STREAM_TOKEN_TTL_SECS=21600
#
# ── Media library WITHOUT the Rust stack (fixture mock, SPA/UI development) ──
# A fixture-backed stub speaks media-core's HTTP surface so you can build the
# media-library UI without running the Rust media-core binary or a real /media
# library. Point the backend at the mock and run it alongside `npm run dev`:
#   1. USE_MEDIA_CORE=1
#   2. MEDIA_CORE_URL=http://127.0.0.1:8095
#   3. INTERNAL_PRINCIPAL_SECRET= any 32+ char placeholder — the mock ignores
#      the Bearer, but the backend proxy fails closed (502) without one.
#   4. npm run dev:media-mock   (second terminal, alongside npm run dev)
# Direct-play only (no transcode/HLS path); binds to 127.0.0.1.
# Port the mock listens on. Default 8095; only consumed by `npm run dev:media-mock`.
MEDIA_CORE_MOCK_PORT=

# ── IPTV / Xtream Codes (mybunny.tv) ─────────────────────────────────────
# Empty XTREAM_* keep boot working without IPTV configured; downstream
# modules guard on XTREAM_HOST being set before any upstream call.
XTREAM_HOST=
XTREAM_USERNAME=
XTREAM_PASSWORD=
# IPTV SQLite DB path. Default ./data/iptv.db.
IPTV_DB_PATH=./data/iptv.db
# Provider XMLTV/EPG endpoint path appended to the Xtream host. Default /xmltv.php.
IPTV_EPG_PATH=/xmltv.php
# Concurrent live-stream cap per server. Default 4.
IPTV_MAX_CONCURRENT_STREAMS=4
# HARD ceiling on simultaneous upstream connections to the IPTV provider,
# enforced at the single point a remux connection opens (no caller can bypass
# it). Exceeding the provider's plan trips an abuse block that then serves
# corrupt video to everyone. Set to your provider's max simultaneous
# connections. Default 2.
IPTV_MAX_UPSTREAM_CONNECTIONS=2
# TTL (secs) for short-lived per-request IPTV stream tokens. Default 300.
IPTV_STREAM_TOKEN_TTL_SECS=300
# Whole-transfer deadline (ms) for Xtream list/account-info fetches. Default 30000.
IPTV_LIST_TIMEOUT_MS=30000
# Deadline (ms) + body cap (bytes) for proxied HLS manifest fetches (small
# text files; must not pin a request open on a drip-feeding upstream).
IPTV_MANIFEST_FETCH_TIMEOUT_MS=10000
IPTV_MANIFEST_MAX_BYTES=2097152
# EPG/catalog sync cron. Default every 6h.
IPTV_SYNC_CRON=0 */6 * * *
# Optional shared secret gating the recommender export endpoint. Leave blank
# to disable that export. Generate with `openssl rand -base64 48` if used.
IPTV_RECOMMENDER_EXPORT_SECRET=
# Scratch dir for IPTV remux segments. Default /tmp/iptv-remux.
IPTV_REMUX_TMP_DIR=/tmp/iptv-remux
# Reviewer-insurance gate (contract §13): set to 1 (or "true") to build an
# instance with NO IPTV surface — /api/iptv routes 404 and the sync cron
# never registers. Default: enabled (unset).
IPTV_DISABLED=
# Optional comma-separated external XMLTV EPG URLs merged into the guide
# (server/services/iptvEpgExternal.ts). Leave blank to use only the provider
# feed.
IPTV_EXTERNAL_EPG_URLS=

# ── Persistent data files ────────────────────────────────────────────────
# JSON/JSONL stores + SQLite DBs. In production these sit on the NAS data
# bind-mount so they survive container restarts; defaults are gitignored
# ./data/* paths for dev. SERVER_DB_PATH especially MUST be bind-mounted in
# Docker — losing it regenerates server_id and silently revokes all device
# tokens.
SERVER_DB_PATH=./data/server.db
REJECTIONS_PATH=./data/rejections.json
USER_FEEDBACK_PATH=./data/user-feedback.json
USAGE_LOG_PATH=./data/usage.jsonl
GRAB_LOG_PATH=./data/grabs.jsonl
# Scheduled VACUUM-INTO snapshots of server.db + iptv.db: retention dir, count
# kept, and cadence. Default daily at 03:30 local, keep 7.
DB_BACKUP_DIR=./data/backups
DB_BACKUP_KEEP=7
DB_BACKUP_CRON=30 3 * * *

# ── Telemetry (§15, amended by plan 006 Phase 0) ─────────────────────────
# Sentry-compatible DSN for the self-hoster's Glitchtip project. Distributed
# to clients at boot via /api/telemetry/config. OPT-IN: the prod boot guard
# only fires when TELEMETRY_ENABLED=1 (set it in deployments that run the
# telemetry stack, so a lost DSN fails loudly). Without a DSN the server
# boots with telemetry off. This is a project ingest endpoint, not a secret
# key, but treat it as config you don't publish.
EEX_TELEMETRY_DSN=
TELEMETRY_ENABLED=
# Version or git SHA stamped at image build time (--build-arg). Surfaced in
# /api/telemetry/config to group crashes by release. Default "dev".
EEX_RELEASE=

# ── CLI-only (not read by the dev server or backend) ─────────────────────
# Used solely by local CLI scripts under scripts/_*.mjs (e.g. the kraken
# video generator). server/env.ts never reads it.
RUNWAYML_API_SECRET=

# ── Sidecar services (docker-compose / local sidecar runs) ───────────────
# These are NOT read by the Node backend — they configure the Rust/Python
# sidecars and are set in docker-compose.yml (or passed when hand-running a
# sidecar; see README "Local full-stack development"). Listed here as a
# pointer so the surface is discoverable; do NOT add them to .env.local
# expecting the backend to read them:
#   MEDIA_INTERNAL_PRINCIPAL_MODE  — media-core principal gate (off|enforce);
#                                    set in docker-compose.yml.
#   MEDIA_CORE_PORT / MEDIA_LIBRARY_PATHS  — media-core listen port + library
#                                    roots (local `cargo run -p media-core`).
#   TRANSCODER_PORT / TRANSCODER_FFMPEG_BIN / TRANSCODER_HW_ENCODER  —
#                                    transcoder process config.
#   TMDB_API_KEY / RECOMMENDER_EVENT_SECRET  — also consumed by the recommender
#                                    sidecar itself (see recommender/README.md).
# The compose file (docker-compose.yml) is the authoritative env reference
# for every sidecar service.
