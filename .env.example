# Local development only — copy to .env.local and fill in real values.
# Real values are in /mnt/user/appdata/{sonarr,radarr,sabnzbd}/* on the NAS.
# These are read by vite.config.ts at dev-server startup and injected
# into proxied requests; they are NOT exposed to the browser.

SONARR_API_KEY=
RADARR_API_KEY=
SAB_API_KEY=

# Backend (Hono) — Plex auth + role-gated API proxying. In dev the
# backend runs on :3001 and Vite proxies /api/auth, /api/me to it.

# Stable UUID identifying this app to plex.tv. Generate once with
# `node -e "console.log(crypto.randomUUID())"` and keep it constant.
# Rotating logs every user out.
PLEX_CLIENT_ID=

# 32+ random bytes used to derive the A256GCM key (via SHA-256) that
# ENCRYPTS session cookies as JWE. The cookie payload includes the
# user's Plex auth token, so encryption — not just signing — is what
# keeps it opaque if the cookie is ever captured or logged. Generate
# with `node -e "console.log(crypto.randomBytes(48).toString('base64url'))"`.
# Rotating invalidates every existing session.
SESSION_SECRET=

# Comma-separated Plex usernames that get the `admin` role. Everyone
# else who is a member of the home server gets `user`. Empty == no
# admins.
ADMINS=

# machineIdentifier of the home Plex server. When unset (default),
# any authenticated Plex user is allowed in — and /api/auth/plex/check
# returns the user's servers in `discoveredServers` so you can grab
# the id and lock things down.
PLEX_SERVER_ID=

# Backend listen port. Default 3001.
PORT=3001

# Production-only — comma-separated SPA origins allowed for CORS,
# e.g. https://theemeraldexchange.com. Leave blank in dev (Vite proxy
# makes everything same-origin).
ALLOWED_ORIGINS=

# Backing service URLs. Defaults match the existing NAS setup; override
# in .env.local if your install is elsewhere or if the urlBase paths
# (Sonarr /tv, Radarr /movies) differ.
# SONARR_URL=http://theemeraldexchange.local:8989/tv
# RADARR_URL=http://theemeraldexchange.local:7878/movies
# SAB_URL=http://theemeraldexchange.local:8080

# Minimum free space (in GB) required on a Sonarr/Radarr root folder
# before /add will succeed. Below this, both admins and users get a 507
# "insufficient_disk_space" — the user explicitly wanted everyone gated.
# Default 100.
MIN_FREE_GB=100

# Optional — only used by local CLI scripts under scripts/_*.mjs (e.g.,
# the kraken video generator). Not consumed by the dev server or the app.
RUNWAYML_API_SECRET=

# mybunny.tv / Xtream Codes
XTREAM_HOST=https://example.mybunny.tv
XTREAM_USERNAME=
XTREAM_PASSWORD=
IPTV_DB_PATH=./data/iptv.db
IPTV_MAX_CONCURRENT_STREAMS=4
IPTV_STREAM_TOKEN_TTL_SECS=300
IPTV_LIST_TIMEOUT_MS=30000
IPTV_SYNC_CRON=0 */6 * * *
IPTV_RECOMMENDER_EXPORT_SECRET=
IPTV_REMUX_TMP_DIR=/tmp/iptv-remux
