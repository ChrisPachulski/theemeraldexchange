# Production env for the NAS-hosted backend + Cloudflare Tunnel sidecar.
#
# Copy this to .env.production (gitignored), fill in real values, and run
# scripts/deploy-nas.sh. It gets shipped to the NAS as ${APPDATA}/.env and
# consumed by docker compose.
#
# Anything starting with VITE_ does NOT belong here — those are SPA build
# vars and live in Netlify's site settings instead.

# ── Cloudflare Tunnel ────────────────────────────────────────────────
# From the Zero Trust dashboard's "Install and run a connector" screen
# (Docker tab). Paste just the eyJh... token, not the full docker run.
TUNNEL_TOKEN=

# ── Backend session signing ──────────────────────────────────────────
# Stable UUID identifying this app to plex.tv. Generate once with
#   node -e 'console.log(crypto.randomUUID())'
# Rotating it logs everyone out.
PLEX_CLIENT_ID=

# Random 32+ byte string used to HMAC-sign session cookies. Generate with:
#   openssl rand -base64 48
# Rotating it logs everyone out.
SESSION_SECRET=

# Comma-separated Plex usernames that get the admin role. Empty = no admins.
ADMINS=ChrisPachulski

# machineIdentifier of the home Plex server. When set, only members of
# that server can log in. Discoverable via the SPA's first login attempt
# in the discoveredServers payload, or:
#   curl -H "X-Plex-Token: <your-token>" https://plex.tv/api/v2/resources | grep clientIdentifier
PLEX_SERVER_ID=

# ── CORS ─────────────────────────────────────────────────────────────
# Comma-separated origins allowed to make credentialed requests.
ALLOWED_ORIGINS=https://theemeraldexchange.com

# ── Backing services (LAN URLs as seen from the backend container) ──
# The container reaches Sonarr/Radarr/SAB via the NAS LAN IP because
# their containers expose ports on the host. Override if you've moved
# them.
SONARR_URL=http://10.0.0.52:8989/tv
SONARR_API_KEY=
RADARR_URL=http://10.0.0.52:7878/movies
RADARR_API_KEY=
SAB_URL=http://10.0.0.52:8080
SAB_API_KEY=

# Minimum free space (GB) on a Sonarr/Radarr root folder before allowing
# an add. Below this, both admins and users get a 507. Default 100.
MIN_FREE_GB=100
