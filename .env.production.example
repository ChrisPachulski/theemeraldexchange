# Production env for the NAS-hosted backend + Cloudflare Tunnel sidecar.
#
# Copy this to .env.production (gitignored), fill in real values, and run
# scripts/deploy-nas.sh. It gets shipped to the NAS as ${APPDATA}/.env and
# consumed by docker compose.
#
# Anything starting with VITE_ does NOT belong here — those are SPA build
# vars and live in Netlify's site settings instead.

# ── Cloudflare Tunnel ────────────────────────────────────────────────
# From the Zero Trust dashboard's "Install and run a connector" screen
# (Docker tab). Paste just the eyJh... token, not the full docker run.
TUNNEL_TOKEN=

# ── Backend session encryption ───────────────────────────────────────
# Stable UUID identifying this app to plex.tv. Generate once with
#   node -e 'console.log(crypto.randomUUID())'
# Rotating it logs everyone out.
PLEX_CLIENT_ID=

# Random 32+ byte string fed through SHA-256 to derive the A256GCM key
# that ENCRYPTS session cookies as JWE. The cookie payload includes
# the user's Plex auth token, so encryption (not just signing) is what
# keeps it opaque if the cookie is ever captured or logged. The
# production env gate rejects anything shorter than 32 bytes or
# matching common placeholder values like "changeme". Generate with:
#   openssl rand -base64 48
# Rotating it logs everyone out.
SESSION_SECRET=

# Comma-separated Plex usernames that get the admin role. Empty = no admins.
ADMINS=ChrisPachulski

# machineIdentifier of the home Plex server. REQUIRED in production —
# the backend refuses to boot otherwise, since a blank value silently
# turns the invitation-only app into "any Plex user can sign in."
# Discoverable via the SPA's first login attempt in the discoveredServers
# payload, or:
#   curl -H "X-Plex-Token: <your-token>" https://plex.tv/api/v2/resources | grep clientIdentifier
PLEX_SERVER_ID=

# Bootstrap escape hatch for the very first deploy, before you've
# discovered your PLEX_SERVER_ID. Set to 1 to allow boot without the
# server id — the app will then accept ANY Plex user. Switch it back to
# 0 (or remove the line) the moment you've copied your server id into
# PLEX_SERVER_ID above. Required passthrough is wired in docker-compose;
# leaving this blank/0 in steady state is the safe default.
ALLOW_UNSCOPED_PLEX_LOGIN=0

# ── CORS ─────────────────────────────────────────────────────────────
# Comma-separated origins allowed to make credentialed requests.
ALLOWED_ORIGINS=https://theemeraldexchange.com

# ── Backing services (LAN URLs as seen from the backend container) ──
# The container reaches Sonarr/Radarr/SAB via the NAS LAN IP because
# their containers expose ports on the host. Override if you've moved
# them.
SONARR_URL=http://10.0.0.52:8989/tv
SONARR_API_KEY=
RADARR_URL=http://10.0.0.52:7878/movies
RADARR_API_KEY=
SAB_URL=http://10.0.0.52:8080
SAB_API_KEY=

# Optional TMDB v3 API key. When set, the detail modal fetches cast
# (movies via /movie/{id}/credits, TV via TVDB→TMDB find then aggregate
# credits). Without it, cast section shows "unavailable". Get a free key
# at https://www.themoviedb.org/settings/api.
TMDB_API_KEY=

# Minimum free space (GB) on a Sonarr/Radarr root folder before allowing
# an add. Below this, both admins and users get a 507. Default 100.
MIN_FREE_GB=100

# Hard cap (GB) on movie release size at add-time. The dashboard
# intercepts Radarr's auto-search, fetches available releases itself,
# and grabs the highest-quality release that's at or under this cap.
# Prevents accidental 50 GB 4K HDR rips. Default 10.
MAX_MOVIE_SIZE_GB=10

# Hard cap (GB) on TV release size, expressed per episode. A release
# passes when (size / episodeCount) ≤ this value. Single-episode releases
# cap at the full per-episode value; an N-episode season pack caps at
# N× this value. 5 GB/ep blocks 4K HDR while permitting 1080p Bluray.
MAX_TV_GB_PER_EPISODE=5

# Exact upstream root-folder paths used for non-admin Sonarr/Radarr adds.
# Set DEFAULT_ROOT_FOLDER_PATH when both services use the same root, or
# override per service when TV and movies live under different roots.
DEFAULT_ROOT_FOLDER_PATH=/data/media
DEFAULT_SONARR_ROOT_FOLDER_PATH=/data/media/tv
DEFAULT_RADARR_ROOT_FOLDER_PATH=/data/media/movies

# Quality-profile name (case-insensitive) the server picks for
# non-admin add requests on both Sonarr and Radarr. Mirrors the
# frontend modal's "Choose Me" preference so a non-admin direct-POST
# lands on the same curated profile, not Sonarr/Radarr's default Any.
# Override per-deploy if the household curates under a different name.
# Default: "choose me".
DEFAULT_PROFILE_NAME=Choose Me
