# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local
.env
.env.local
.env.*.local
.env.production
!.env.production.example

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Python bytecode (recommender app + parity tests)
__pycache__/
*.pyc

# Internal-only docs & planning — kept locally, never published to the public repo
docs/
plans/
.planning/

# Netlify CLI state (machine-local; hardcodes an absolute publish path)
.netlify/

# Local tooling
.claude/
.graphify/
.agents/
skills-lock.json

# Scratch scripts (underscore-prefixed in scripts/ are local-only)
scripts/_*

# Vitest coverage output
coverage

# Playwright artifacts
playwright-report/
test-results/

# Local grab-event log (production lives on the NAS bind-mount)
data/
.dev_notes/

# iptv sqlite + remux tmpdirs
/tmp/iptv-remux/

# Rust workspace build artifacts (emerald-contracts crate)
/target/

# Prebuilt eex-ytresolve binary, fetched from the rust-yt-extractor release at
# deploy time into the Docker build context (Dockerfile COPYs bin/eex-ytresolve).
# 11.9 MB; built in CI, never committed — the source lives in its own repo.
/bin/eex-ytresolve

# napi-rs build artifacts — produced by `npm run build:napi` (or the napi
# crate's `prepare` script). One .node per host triple; not portable, not
# checked in. The Planning agent's M2 deploy plan compiles these in the
# Docker image build step.
crates/emerald-contracts-napi/*.node

# PyO3 binding: extension module + venv built by `maturin develop`. The
# .so is host-triple-specific; the venv is a developer convenience only.
crates/emerald-contracts-pyo3/.venv/
crates/emerald-contracts-pyo3/*.so
crates/emerald-contracts-pyo3/*.pyd

.planning/burn-it-all/

# Recs eval-run artifacts. The eval suite now writes to $TMPDIR/eex-eval-runs
# (see server/routes/suggestions.eval.test.ts); these in-tree stragglers are
# generated output, not source. Pre-2026-06 runs remain tracked as history.
.planning/ai-recommendations-loop/eval-runs/

# Playwright-MCP browser session scratch (page snapshots, traces)
.playwright-mcp/

# Auto-generated session resume state (regenerated each Stop/PreCompact)
.eex/

# audit artifacts
.audit_allfiles.txt
docs/audit-results.json
docs/PRODUCTION-AUDIT.html

# Local uv resolver output. Do not commit until Docker/CI consume uv.lock.
recommender/uv.lock

# Offline recsys-eval venv (numpy + sqlite-vec + pydantic); host-specific.
recommender/.venv-eval/

# BGE content-embedding venv (torch + sentence-transformers); host-specific.
recommender/.venv-embed/

# local security audit scratch + exposure-monitor state (not committed)
.security-audit/
scripts/security/.exposure-baseline.json
scripts/security/exposure-drift.log
