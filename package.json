{
  "name": "theemeraldexchange",
  "private": true,
  "version": "0.0.0",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "concurrently -n vite,api -c cyan,magenta \"npm:dev:vite\" \"npm:dev:server\"",
    "dev:vite": "vite",
    "dev:server": "tsx watch server/index.ts",
    "dev:media-mock": "tsx watch server/mocks/mediaCoreMock.ts",
    "build": "tsc -b && vite build && tsc -p server/tsconfig.json",
    "build:spa": "tsc -b && vite build",
    "build:server": "tsc -p server/tsconfig.json",
    "start": "tsx server/index.ts",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e:integration": "PW_INTEGRATION=1 playwright test --project=integration",
    "test:e2e:playback": "PW_INTEGRATION=1 playwright test --project=playback-chrome",
    "test:e2e:all": "npm run test:e2e && npm run test:e2e:integration && npm run test:e2e:playback",
    "eval:recs": "vitest run --config vitest.eval.config.ts",
    "build:napi": "npm --prefix crates/emerald-contracts-napi run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.111.0",
    "@emerald/contracts-napi": "file:./crates/emerald-contracts-napi",
    "@hono/node-server": "^2.0.8",
    "@sentry/node": "10.65.0",
    "@sentry/react": "10.65.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.2",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-virtual": "^3.14.5",
    "better-sqlite3": "12.11.1",
    "dotenv": "^17.4.2",
    "hls.js": "^1.6.16",
    "hono": "^4.12.29",
    "jose": "^6.2.3",
    "mpegts.js": "^1.8.0",
    "node-cron": "^4.6.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sax": "^1.6.0",
    "three": "^0.185.1",
    "tsx": "^4.23.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "26.1.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/sax": "^1.2.7",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "concurrently": "10.0.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.3",
    "vitest": "4.1.9"
  }
}
