{
  "_meta": {
    "format_version": 1,
    "authored_from": "§15.3 (PII scrub key list, 7 items) + rsrch-s15-pii-scrubber §6.3 (key-to-implementation mapping), cross-service-contract 2026-05-25",
    "author": "ChrisPachulski",
    "date": "2026-05-26",
    "reviewed_by": "ChrisPachulski"
  },
  "cases": [
    {
      "id": "plex-auth-token-in-extra",
      "description": "§15.3 item 1: plexAuthToken field in event.extra must be replaced with REDACTED.",
      "input": {
        "extra": {
          "plexAuthToken": "some-real-plex-token-abc123",
          "requestId": "req-001"
        }
      },
      "expected": {
        "extra": {
          "plexAuthToken": "REDACTED",
          "requestId": "req-001"
        }
      }
    },
    {
      "id": "verified-plex-server-id-in-extra",
      "description": "§15.3 item 2: verifiedPlexServerId field in event.extra must be replaced with REDACTED.",
      "input": {
        "extra": {
          "verifiedPlexServerId": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
          "action": "sync"
        }
      },
      "expected": {
        "extra": {
          "verifiedPlexServerId": "REDACTED",
          "action": "sync"
        }
      }
    },
    {
      "id": "xtream-credentials-in-extra",
      "description": "§15.3 items 3+4: XTREAM_USERNAME and XTREAM_PASSWORD in event.extra must both be replaced.",
      "input": {
        "extra": {
          "XTREAM_USERNAME": "household_user",
          "XTREAM_PASSWORD": "hunter2",
          "host": "provider.example.com"
        }
      },
      "expected": {
        "extra": {
          "XTREAM_USERNAME": "REDACTED",
          "XTREAM_PASSWORD": "REDACTED",
          "host": "provider.example.com"
        }
      }
    },
    {
      "id": "stream-grant-token-in-request-url",
      "description": "§15.3 item 5: stream-grant token in request.url query param t= must be replaced with REDACTED.",
      "input": {
        "request": {
          "url": "http://server.local/api/iptv/stream/live/42?t=4b0b2e5892535269eddb6a080143edaae77ca3227572f4406221ab4c2eb1ec1f&fmt=hls",
          "method": "GET"
        }
      },
      "expected": {
        "request": {
          "url": "http://server.local/api/iptv/stream/live/42?t=REDACTED&fmt=hls",
          "method": "GET"
        }
      }
    },
    {
      "id": "bearer-token-in-authorization-header",
      "description": "§15.3 item 6: Authorization: Bearer <device-token> header must be replaced.",
      "input": {
        "request": {
          "headers": {
            "authorization": "Bearer eyJhbGciOiJkaXIiLCJlbmMiOiJBMjU2R0NNIiwia2lkIjoiZGV2aWNlLXYxIn0..rYVfdZOx1tm42yKd.kusq7DC5g4aop.6O419Fjcms4oyowjwFA7pg",
            "content-type": "application/json"
          },
          "method": "GET",
          "url": "/api/iptv/channels"
        }
      },
      "expected": {
        "request": {
          "headers": {
            "authorization": "REDACTED",
            "content-type": "application/json"
          },
          "method": "GET",
          "url": "/api/iptv/channels"
        }
      }
    },
    {
      "id": "session-cookie-in-cookie-header",
      "description": "§15.3 item 6 (cookie branch): eex.session=<JWE> in Cookie header must have the value replaced.",
      "input": {
        "request": {
          "headers": {
            "cookie": "eex.session=eyJhbGciOiJkaXIiLCJlbmMiOiJBMjU2R0NNIn0..abc.def.ghi; theme=dark; lang=en",
            "host": "server.local"
          },
          "method": "POST",
          "url": "/api/auth/logout"
        }
      },
      "expected": {
        "request": {
          "headers": {
            "cookie": "REDACTED",
            "host": "server.local"
          },
          "method": "POST",
          "url": "/api/auth/logout"
        }
      }
    },
    {
      "id": "jwe-ciphertext-in-sql-param",
      "description": "§15.3 item 7: JWE ciphertext appearing as a SQL parameter value must be replaced by JWE_CIPHERTEXT_RE.",
      "input": {
        "extra": {
          "sqlParam": "eyJhbGciOiJkaXIiLCJlbmMiOiJBMjU2R0NNIn0.abc123def456.ghijklmn.opqrstuv.wxyz1234",
          "query": "SELECT * FROM sessions WHERE token = ?"
        }
      },
      "expected": {
        "extra": {
          "sqlParam": "REDACTED.",
          "query": "SELECT * FROM sessions WHERE token = ?"
        }
      }
    }
  ]
}
